# ==========================================================
# OpenWrt / ImmortalWrt qualcommax ipq60xx
# all device profiles kept
# built-in minimal Docker + HomeProxy + USB printer driver
# avoid opkg post-install for kmod-usb-printer / docker dependencies
# ==========================================================

CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_cmiot_ax18=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_cmiot_ax18="ipq-wifi-cmiot_ax18"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-ax1800=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_glinet_gl-ax1800="ipq-wifi-glinet_gl-ax1800"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-axt1800=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_glinet_gl-axt1800="ipq-wifi-glinet_gl-axt1800"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_ax1800-pro=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_ax1800-pro="ipq-wifi-jdcloud_ax1800-pro"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_ax6600=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_ax6600="ipq-wifi-jdcloud_ax6600 ath11k-firmware-qcn9074 kmod-ath11k-pci"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_qihoo_v6=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_qihoo_v6="ipq-wifi-qihoo_v6"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_redmi_ax5="ipq-wifi-redmi_ax5"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5-jdcloud=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_redmi_ax5-jdcloud="ipq-wifi-redmi_ax5-jdcloud"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_xiaomi_ax1800=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_xiaomi_ax1800="ipq-wifi-xiaomi_ax1800"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_zn_m2="ipq-wifi-zn_m2"


# =========================
# Kernel / BusyBox / defaults
# =========================

CONFIG_IPV6=y
CONFIG_BUSYBOX_CUSTOM=y
CONFIG_BUSYBOX_CONFIG_LSUSB=y
# CONFIG_KERNEL_DEVMEM is not set
# CONFIG_BUSYBOX_CONFIG_DEVMEM is not set

CONFIG_ATH11K_MEM_PROFILE_512M=y

CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y


# =========================
# Base network: fw4 + nftables
# These lines are important for packages that depend on virtual
# iptables / ip6tables / uci-firewall.
# =========================

CONFIG_PACKAGE_firewall4=y
# CONFIG_PACKAGE_firewall is not set

CONFIG_PACKAGE_ip-full=y
# CONFIG_PACKAGE_ip-tiny is not set
CONFIG_PACKAGE_ipv6helper=y

CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip6tables-nft=y
CONFIG_PACKAGE_xtables-nft=y
# CONFIG_PACKAGE_iptables-zz-legacy is not set
# CONFIG_PACKAGE_ip6tables-zz-legacy is not set

CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-nft-compat=y

CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-netlink-diag=y
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=y

# Docker dependency side: keep only what dockerd normally requires.
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipt-extra=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_kmod-ipt-physdev=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_kmod-nf-ipvs=y

# Not needed for this minimal image unless another plugin explicitly requires them.
# CONFIG_PACKAGE_iptables-mod-nat-extra is not set
# CONFIG_PACKAGE_kmod-nf-nathelper is not set
# CONFIG_PACKAGE_kmod-nf-nathelper-extra is not set
# CONFIG_PACKAGE_kmod-nft-fullcone is not set
# CONFIG_PACKAGE_kmod-nfnetlink-queue is not set
# CONFIG_PACKAGE_kmod-nft-queue is not set
# CONFIG_PACKAGE_miniupnpd-nftables is not set


# =========================
# Docker built into firmware, minimal, SSH management only
# =========================

CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_docker=y
CONFIG_PACKAGE_containerd=y
CONFIG_PACKAGE_runc=y
CONFIG_PACKAGE_tini=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_cgroupfs-mount=y
CONFIG_PACKAGE_libseccomp=y

CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-br-netfilter=y
CONFIG_PACKAGE_kmod-fs-overlayfs=y

# No Docker GUI / compose.
# CONFIG_PACKAGE_luci-app-dockerman is not set
# CONFIG_PACKAGE_docker-compose is not set

# Docker optional features off to reduce size.
# CONFIG_DOCKER_CHECK_CONFIG is not set
# CONFIG_DOCKER_CGROUP_OPTIONS is not set
# CONFIG_DOCKER_OPTIONAL_FEATURES is not set
# CONFIG_DOCKER_NET_OVERLAY is not set
# CONFIG_DOCKER_NET_ENCRYPT is not set
# CONFIG_DOCKER_NET_MACVLAN is not set
# CONFIG_DOCKER_NET_TFTP is not set
# CONFIG_DOCKER_STO_DEVMAPPER is not set
# CONFIG_DOCKER_STO_BTRFS is not set


# =========================
# HomeProxy / sing-box
# =========================

CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_ucode-mod-digest=y


# =========================
# LuCI base
# Needed because HomeProxy is a LuCI app. Keep only base components.
# =========================

CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-jsonc=y
CONFIG_PACKAGE_luci-lib-nixio=y
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_luci-compat=y

CONFIG_PACKAGE_lua=y
CONFIG_PACKAGE_liblua=y
CONFIG_PACKAGE_libubus-lua=y
CONFIG_PACKAGE_liblucihttp-lua=y
CONFIG_PACKAGE_ucode-mod-lua=y

# Optional package-manager page. Disable if you do not need LuCI software page.
# CONFIG_PACKAGE_luci-lib-ipkg is not set


# =========================
# USB base
# =========================

CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-roles=y
CONFIG_PACKAGE_kmod-usb-wdm=y
CONFIG_PACKAGE_usb-modeswitch=y

# BusyBox lsusb is enabled above, so do not install full usbutils.
# CONFIG_PACKAGE_usbutils is not set

# IPQ60xx generally does not need these old/PCI USB host controller modules.
# CONFIG_PACKAGE_kmod-usb2-pci is not set
# CONFIG_PACKAGE_kmod-usb-dwc2 is not set
# CONFIG_PACKAGE_kmod-usb-dwc2-pci is not set
# CONFIG_PACKAGE_kmod-usb-uhci is not set
# CONFIG_PACKAGE_kmod-usb-ehci is not set
# CONFIG_PACKAGE_kmod-usb-ohci is not set
# CONFIG_PACKAGE_kmod-usb-ohci-pci is not set
# CONFIG_PACKAGE_kmod-usb-phy-nop is not set


# =========================
# USB printer built into firmware
# Do not install it with opkg after flashing.
# =========================

CONFIG_PACKAGE_kmod-usb-printer=y
CONFIG_PACKAGE_p910nd=y

# No print GUI, to avoid luci-app-usb-printer / luci-app-p910nd dependency chains.
# Configure p910nd by UCI/SSH after flashing.
# CONFIG_PACKAGE_luci-app-usb-printer is not set
# CONFIG_PACKAGE_luci-app-p910nd is not set
# CONFIG_PACKAGE_kmod-lp is not set


# =========================
# USB storage, ext4 only
# Useful for Docker data directory, but still kept small.
# =========================

CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_kmod-nls-utf8=y

# Ext4 only. Keep other filesystems off.
# CONFIG_PACKAGE_kmod-usb-storage-extras is not set
# CONFIG_PACKAGE_kmod-fs-f2fs is not set
# CONFIG_PACKAGE_kmod-fs-ntfs3 is not set
# CONFIG_PACKAGE_kmod-fs-vfat is not set
# CONFIG_PACKAGE_kmod-fs-xfs is not set
# CONFIG_PACKAGE_ntfs3-mount is not set
# CONFIG_PACKAGE_kmod-fs-exportfs is not set
# CONFIG_PACKAGE_kmod-nls-cp437 is not set
# CONFIG_PACKAGE_kmod-nls-iso8859-1 is not set

# Disk GUI and large disk tools off.
# CONFIG_PACKAGE_luci-app-diskman is not set
# CONFIG_PACKAGE_luci-app-hd-idle is not set
# CONFIG_PACKAGE_cfdisk is not set
# CONFIG_PACKAGE_fdisk is not set
# CONFIG_PACKAGE_lsblk is not set
# CONFIG_PACKAGE_parted is not set
# CONFIG_PACKAGE_tune2fs is not set
# CONFIG_PACKAGE_hdparm is not set
# CONFIG_PACKAGE_smartmontools-drivedb is not set
# CONFIG_PACKAGE_fstrim is not set
# CONFIG_PACKAGE_dmesg is not set


# =========================
# 4G / 5G USB modem support
# Kept from your original requirements. Remove protocols you do not use.
# =========================

CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-huawei-cdc-ncm=y

CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y
CONFIG_PACKAGE_kmod-usb-acm=y

CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_umbim=y
CONFIG_PACKAGE_comgt=y
CONFIG_PACKAGE_comgt-ncm=y
CONFIG_PACKAGE_wwan=y

CONFIG_PACKAGE_luci-proto-qmi=y
CONFIG_PACKAGE_luci-proto-mbim=y
CONFIG_PACKAGE_luci-proto-ncm=y
CONFIG_PACKAGE_luci-proto-3g=y

CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_chat=y


# =========================
# Small utilities only
# =========================

CONFIG_PACKAGE_etherwake=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lz4=y
CONFIG_PACKAGE_kmod-crypto-crc32=y
CONFIG_PACKAGE_kmod-crypto-acompress=y

# Avoid libncursesw6 pull from terminal apps such as screen.
# CONFIG_PACKAGE_screen is not set
# CONFIG_PACKAGE_libncurses is not set
# CONFIG_PACKAGE_terminfo is not set

# Avoid unnecessary library pinning; let selected packages pull exact ABI packages.
# CONFIG_PACKAGE_coreutils is not set
# CONFIG_PACKAGE_coreutils-nohup is not set
# CONFIG_PACKAGE_libuv is not set
# CONFIG_PACKAGE_libwebsockets-full is not set
# CONFIG_PACKAGE_libfuse is not set
# CONFIG_PACKAGE_mmc-utils is not set
# CONFIG_PACKAGE_acme-acmesh-dnsapi is not set


# =========================
# U2F / FIDO2 / OpenSSH client off by default
# =========================

# CONFIG_PACKAGE_libfido2 is not set
# CONFIG_PACKAGE_libcbor is not set
# CONFIG_PACKAGE_libudev is not set
# CONFIG_PACKAGE_libopenssl-legacy is not set
# CONFIG_PACKAGE_openssh-client is not set
# CONFIG_PACKAGE_openssh-keygen is not set
# CONFIG_PACKAGE_openssh-server is not set


# =========================
# Explicitly disabled LuCI apps / extras
# =========================

# CONFIG_PACKAGE_luci-app-cpufreq is not set
# CONFIG_PACKAGE_kmod-sound-core is not set
# CONFIG_PACKAGE_luci-app-upnp is not set
# CONFIG_PACKAGE_luci-app-arpbind is not set
# CONFIG_PACKAGE_OpenAppFilter is not set
# CONFIG_PACKAGE_luci-app-qos is not set
# CONFIG_PACKAGE_luci-app-vsftpd is not set
# CONFIG_PACKAGE_luci-app-parentalcontrol is not set
# CONFIG_PACKAGE_luci-app-gecoosac is not set
# CONFIG_PACKAGE_luci-app-lucky is not set
# CONFIG_PACKAGE_luci-app-onliner is not set
